# ============================================
# Roomify AI - Environment Variables (TEMPLATE)
# ============================================
# Copy to .env and fill in real values. Never commit .env.
#
#   cp .env.example .env
# ============================================

# --- Database ---
# MySQL connection string. Format:
#   mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://username:password@host:3306/database

# --- AI Image Generation ---
# Pick ONE provider and supply its credentials below.
# Options: mock | pollinations | cloudflare | gemini | leonardo | openai | stability | replicate
AI_PROVIDER=cloudflare

# Cloudflare Workers AI (free 10k neurons/day, supports img2img)
# Account ID: dashboard right sidebar at https://dash.cloudflare.com
# API token: https://dash.cloudflare.com/profile/api-tokens (Workers AI: Edit)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Google Gemini (free tier, supports img2img)
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Leonardo AI (150 free images/day, supports img2img)
# Get key: https://leonardo.ai/settings/api-access
LEONARDO_API_KEY=

# Pollinations (no key required, text-to-image only)
# Nothing to set — just AI_PROVIDER=pollinations

# OpenAI DALL-E 3 (paid)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Stability AI SDXL (paid)
# Get key: https://platform.stability.ai/account/keys
STABILITY_API_KEY=

# Replicate (paid)
# Get token: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# --- Amazon Associates Affiliate ---
# Your Amazon affiliate tracking ID. Format: yourname-21
# Sign up: https://affiliate-program.amazon.in/
AFFILIATE_TAG=

# --- Runtime ---
# Only required in production deployment (PM2 / docker / systemd).
NODE_ENV=development
PORT=3000
